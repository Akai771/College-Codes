@model MVCView.Models.Employee

@{
    ViewBag.Title = "Index";
}

<h2>Employee Details</h2>

<table border="1">

    <tr>
        <td>Employee ID</td>
        <td>@Model.eid</td>
    </tr>

    <tr>
        <td>Employee Name</td>
        <td>@Model.ename</td>
    </tr>

    <tr>
        <td>Department</td>
        <td>@Model.department</td>
    </tr>

    <tr>
        <td>Salary</td>
        <td>@Model.salary</td>
    </tr>

</table>

